# PostgreSQL (docker-compose / backend)
POSTGRES_DB=bank_db
POSTGRES_USER=bank_user
POSTGRES_PASSWORD=bank_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT после ввода PIN (в проде: openssl rand -hex 32)
APP_JWT_SECRET=

# VK Mini App: защищённый ключ приложения
VK_APP_SECRET=

# Локальная отладка без подписи launch_params (в проде удалите или поставьте 0)
VK_SKIP_LAUNCH_VERIFY=1

# Сообщество VK: токен с правом messages, числовой ID группы
VK_GROUP_ACCESS_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199

# Админ-API: если задан, клиенты должны слать заголовок X-Admin-Key
ADMIN_API_KEY=
